{
  "uid": "backend-scalability",
  "title": "Backend Scalability Overview",
  "tags": ["benchmark", "scalability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP Request Rate By Service",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum by (application, uri) (rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "{{application}} {{uri}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP p95 Latency By Service",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "histogram_quantile(0.95, sum by (application, uri, le) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "{{application}} {{uri}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Container CPU Usage",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\".*benchmark.*\"}[1m]))",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "JVM Heap Used",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum by (application) (jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Kafka Consumer Lag",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum by (consumergroup, topic) (kafka_consumergroup_lag)",
          "legendFormat": "{{consumergroup}} {{topic}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Redis Hit Ratio Inputs",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rate(redis_keyspace_hits_total[1m])",
          "legendFormat": "hits"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rate(redis_keyspace_misses_total[1m])",
          "legendFormat": "misses"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Gateway Connections",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "nginx_connections_active",
          "legendFormat": "active"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "nginx_connections_waiting",
          "legendFormat": "waiting"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "DB Pool Active Connections",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum by (application, pool) (hikaricp_connections_active)",
          "legendFormat": "{{application}} {{pool}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "HTTP Error Rate By Service",
      "gridPos": { "x": 0, "y": 32, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum by (application, uri, status) (rate(http_server_requests_seconds_count{status=~\"5..\"}[1m]))",
          "legendFormat": "{{application}} {{uri}} {{status}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "bargauge",
      "title": "Top Tracks By Global Plays",
      "gridPos": { "x": 12, "y": 32, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "topk(10, analytics_global_chart_play_count)",
          "legendFormat": "{{song_id}}"
        }
      ]
    }
  ]
}
