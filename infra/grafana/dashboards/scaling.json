{
  "title": "Music Streaming \u2014 Scaling Metrics",
  "uid": "music-streaming-scaling",
  "schemaVersion": 39,
  "tags": [
    "music-streaming",
    "scaling"
  ],
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate per Service",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(http_server_requests_seconds_count{uri!~\".*actuator.*\"}[1m])) by (job)",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "options": {},
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "HTTP Error Rate per Service",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
