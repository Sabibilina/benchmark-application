{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Music Streaming — scaling decision dashboard. Shows the metrics needed to decide when and what to scale.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Request Throughput",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (application) (rate(http_server_requests_seconds_count{uri!~\".*(actuator|health|prometheus).*\"}[1m]))",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ],
      "title": "HTTP Request Rate per Service (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 0.1,
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "targets": [
        {
          "expr": "sum by (application) (rate(http_server_requests_seconds_count{status=~\"5..\", uri!~\".*(actuator|health).*\"}[1m])) / sum by (application) (rate(http_server_requests_seconds_count{uri!~\".*(actuator|health).*\"}[1m]))",
          "legendFormat": "{{application}} error rate",
          "refId": "A"
        }
      ],
      "title": "HTTP 5xx Error Rate per Service",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 4,
      "title": "Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 5,
      "targets": [
        {
          "expr": "sum by (application) (rate(http_server_requests_seconds_sum{uri!~\".*(actuator|health|prometheus).*\"}[1m])) / sum by (application) (rate(http_server_requests_seconds_count{uri!~\".*(actuator|health|prometheus).*\"}[1m]))",
          "legendFormat": "{{application}} avg",
          "refId": "A"
        }
      ],
      "title": "Average Request Latency per Service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 6,
      "targets": [
        {
          "expr": "http_server_requests_seconds_max{uri!~\".*(actuator|health|prometheus).*\"}",
          "legendFormat": "{{application}} max",
          "refId": "A"
        }
      ],
      "title": "Max Observed Request Latency per Service (scaling trigger at 2 s)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 7,
      "title": "JVM & CPU",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 8,
      "targets": [
        {
          "expr": "sum by (application) (jvm_memory_used_bytes{area=\"heap\"}) / sum by (application) (jvm_memory_max_bytes{area=\"heap\"})",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ],
      "title": "JVM Heap Usage % (scale alert at 85 %)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "red", "value": 0.8 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 9,
      "targets": [
        {
          "expr": "process_cpu_usage",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ],
      "title": "CPU Usage per Service (scale alert at 70 %)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 10,
      "title": "Database Connection Pools",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "red", "value": 0.8 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "id": 11,
      "targets": [
        {
          "expr": "hikaricp_connections_active / hikaricp_connections_max",
          "legendFormat": "{{application}} {{pool}}",
          "refId": "A"
        }
      ],
      "title": "HikariCP Pool Saturation (add PgBouncer at 80 %)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "id": 12,
      "targets": [
        {
          "expr": "pg_stat_activity_count{state=\"active\"}",
          "legendFormat": "{{datname}} active",
          "refId": "A"
        },
        {
          "expr": "pg_stat_user_tables_seq_scan",
          "legendFormat": "{{relname}} seq scans",
          "refId": "B"
        }
      ],
      "title": "PostgreSQL Active Connections & Sequential Scans (seq scans → missing index)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 13,
      "title": "Kafka Consumer Lag (primary scaling signal for async services)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 10000 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 37 },
      "id": 14,
      "targets": [
        {
          "expr": "kafka_consumergroup_lag{consumergroup=\"analytics-service\"}",
          "legendFormat": "analytics lag (topic={{topic}}, partition={{partition}})",
          "refId": "A"
        }
      ],
      "title": "Kafka Consumer Lag — analytics-service (add replicas when >10 K)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 10000 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 37 },
      "id": 15,
      "targets": [
        {
          "expr": "kafka_consumergroup_lag{consumergroup=\"recommendation-service\"}",
          "legendFormat": "recommend lag (topic={{topic}}, partition={{partition}})",
          "refId": "A"
        },
        {
          "expr": "kafka_consumergroup_lag{consumergroup=\"notification-service\"}",
          "legendFormat": "notification lag (topic={{topic}}, partition={{partition}})",
          "refId": "B"
        }
      ],
      "title": "Kafka Consumer Lag — recommendation & notification",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 45 },
      "id": 16,
      "title": "Redis & OpenSearch",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 46 },
      "id": 17,
      "targets": [
        {
          "expr": "redis_keyspace_hits_total / (redis_keyspace_hits_total + redis_keyspace_misses_total)",
          "legendFormat": "Redis hit rate",
          "refId": "A"
        }
      ],
      "title": "Redis Cache Hit Rate (low → cold cache or TTL too short)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 419430400 },
              { "color": "red", "value": 503316480 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 46 },
      "id": 18,
      "targets": [
        {
          "expr": "redis_used_memory_bytes",
          "legendFormat": "Redis used memory",
          "refId": "A"
        },
        {
          "expr": "redis_used_memory_peak_bytes",
          "legendFormat": "Redis peak memory",
          "refId": "B"
        }
      ],
      "title": "Redis Memory (alert at 80 % of maxmemory 512 MB = 409 MB)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 46 },
      "id": 19,
      "targets": [
        {
          "expr": "opensearch_jvm_mem_heap_used_in_bytes / opensearch_jvm_mem_heap_max_in_bytes",
          "legendFormat": "OpenSearch heap %",
          "refId": "A"
        }
      ],
      "title": "OpenSearch JVM Heap % (add second node at 75 %)",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 39,
  "tags": ["music-streaming", "scaling"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Music Streaming — Scaling Dashboard",
  "uid": "music-streaming-scaling",
  "version": 1
}
