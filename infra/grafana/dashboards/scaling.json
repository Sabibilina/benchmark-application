          "expr": "sum(rate(http_server_requests_seconds_count{uri!~\".*actuator.*\",status=~\"5..\"}[1m])) by (job)",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "options": {},
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
