# Streaming Service — environment variables

# Kafka broker address (internal Docker network address for compose; localhost:29092 for local dev)
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# Path to the Auth Service RSA public key for JWT verification
JWT_PUBLIC_KEY_PATH=/jwt-keys/public.pem

# Size of each simulated HLS segment payload in bytes
STREAM_SEGMENT_SIZE_BYTES=65536

# Number of segments listed in each HLS manifest
STREAM_SEGMENT_COUNT=10

# Kafka topic for playback events (consumed by Analytics and Recommendation services)
KAFKA_TOPIC_PLAYBACK_EVENTS=playback-events
