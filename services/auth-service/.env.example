# Auth Service — environment variables
# Used when running the service outside of docker-compose (e.g. locally with mvn spring-boot:run).
# In docker-compose these values are supplied via the environment: block.

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/authdb
SPRING_DATASOURCE_USERNAME=authuser
SPRING_DATASOURCE_PASSWORD=authpass

# Directory where the RSA key pair is written (private.pem) and read (public.pem)
JWT_KEY_DIR=/jwt-keys

# JWT token lifetime in milliseconds (default: 1 hour)
JWT_EXPIRATION_MS=3600000
