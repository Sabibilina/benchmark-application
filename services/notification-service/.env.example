# Notification Service — environment variables

# MongoDB connection URI
SPRING_DATA_MONGODB_URI=mongodb://mongouser:mongopass@localhost:27017/notificationdb?authSource=admin

# Kafka bootstrap
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# Kafka topic consumed (must match Playlist Service producer topic)
KAFKA_TOPIC_PLAYLIST_EVENTS=playlist-events

# Kafka consumer group
KAFKA_CONSUMER_GROUP_ID=notification-service

# Path to RSA public key written by Auth Service (mounted via jwt-keys volume)
JWT_PUBLIC_KEY_PATH=/jwt-keys/public.pem
