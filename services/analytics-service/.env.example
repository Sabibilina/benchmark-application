# Analytics Service — environment variables

CLICKHOUSE_HOST=localhost
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_DB=analyticsdb
CLICKHOUSE_USER=analyticsuser
CLICKHOUSE_PASSWORD=analyticspass

SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_TOPIC_PLAYBACK_EVENTS=playback-events
KAFKA_CONSUMER_GROUP_ID=analytics-service

# Path to the Auth Service RSA public key for JWT verification
JWT_PUBLIC_KEY_PATH=/jwt-keys/public.pem

# Maximum number of history entries returned per request
ANALYTICS_HISTORY_LIMIT=100
