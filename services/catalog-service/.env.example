# Catalog Service — environment variables

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/catalogdb
SPRING_DATASOURCE_USERNAME=cataloguser
SPRING_DATASOURCE_PASSWORD=catalogpass

# JWT — path to Auth Service RSA public key (shared via jwt-keys Docker volume)
JWT_PUBLIC_KEY_PATH=/jwt-keys/public.pem

# Seed — set to false to skip CSV import (e.g. when running tests independently)
CATALOG_SEED_ENABLED=true
CATALOG_SEED_BATCH_SIZE=500
