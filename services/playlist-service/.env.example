# Playlist Service — environment variables

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5434/playlistdb
SPRING_DATASOURCE_USERNAME=playlistuser
SPRING_DATASOURCE_PASSWORD=playlistpass

SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# Path to the Auth Service RSA public key for JWT verification
JWT_PUBLIC_KEY_PATH=/jwt-keys/public.pem
