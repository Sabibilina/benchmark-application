# Recommendation Service — environment variables

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5435/recommendationdb
SPRING_DATASOURCE_USERNAME=recommendationuser
SPRING_DATASOURCE_PASSWORD=recommendationpass

SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# Path to the Auth Service RSA public key for JWT verification
JWT_PUBLIC_KEY_PATH=/jwt-keys/public.pem

# Kafka topic and consumer group (must match streaming-service KAFKA_TOPIC_PLAYBACK_EVENTS)
KAFKA_TOPIC_PLAYBACK_EVENTS=playback-events
KAFKA_CONSUMER_GROUP_ID=recommendation-service

# Recommendation tuning
RECOMMENDATION_DAILY_MIX_SIZE=20
RECOMMENDATION_SIMILAR_SIZE=10
RECOMMENDATION_CACHE_TTL_SECONDS=3600

# Set to false to skip CSV seed on startup (useful for testing)
RECOMMENDATION_SEED_ENABLED=true
