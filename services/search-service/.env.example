# Search Service — environment variables

# OpenSearch connection
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_INDEX_NAME=songs

# Path to the Auth Service RSA public key for JWT verification
JWT_PUBLIC_KEY_PATH=/jwt-keys/public.pem

# Search result cap (tunable for benchmarking)
SEARCH_MAX_RESULTS=20

# Index seeding
SEARCH_SEED_ENABLED=true
SEARCH_SEED_BATCH_SIZE=500
