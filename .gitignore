# Environment — copy .env.example to .env; never commit .env
.env

# JWT key pair — generated at runtime, never committed
shared/jwt/*.pem
shared/jwt/*.key

# Java / Maven
**/target/
**/.mvn/wrapper/maven-wrapper.jar
**/mvn
!**/mvn/wrapper/maven-wrapper.properties

# Node / frontend
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Docker
**/.docker/

# IDEs
.idea/
.vscode/
*.iml
*.iws
*.ipr

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Load test seed data — contains test credentials, generated at runtime
load-generator/scripts/data/seed.json
load-generator/scripts/data/

