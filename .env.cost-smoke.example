# Optional lower-footprint overrides for:
# docker compose --env-file .env.cost-smoke.example -f docker-compose.yml -f docker-compose.cost-smoke.yml up -d

COST_PROFILE=cost-smoke

DEFAULT_SERVICE_CPUS=0.35
DEFAULT_SERVICE_MEMORY=384m
INFRA_CPUS=0.50
INFRA_MEMORY=512m
GATEWAY_CPUS=0.35
GATEWAY_MEMORY=128m
K6_USER=0:0

POSTGRES_CPUS=0.35
POSTGRES_MEMORY=512m
KAFKA_CPUS=0.50
KAFKA_MEMORY=768m
OPENSEARCH_CPUS=0.75
OPENSEARCH_MEMORY=1536m
CLICKHOUSE_CPUS=0.50
CLICKHOUSE_MEMORY=1g
REDIS_CPUS=0.25
REDIS_MEMORY=256m
MONGO_CPUS=0.35
MONGO_MEMORY=512m

PROMETHEUS_RETENTION_TIME=2h
PROMETHEUS_RETENTION_SIZE=256MB
KAFKA_LOG_RETENTION_HOURS=6
KAFKA_LOG_RETENTION_BYTES=268435456
REDIS_APPENDONLY=no
REDIS_MAXMEMORY=128mb
REDIS_MAXMEMORY_POLICY=allkeys-lru
