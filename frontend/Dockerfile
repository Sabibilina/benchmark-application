FROM node:20-alpine AS build

WORKDIR /app
ARG VITE_AUTH_API_BASE_URL=http://localhost:8081
ARG VITE_CATALOG_API_BASE_URL=http://localhost:8082
ARG VITE_STREAMING_API_BASE_URL=http://localhost:8083
ARG VITE_PLAYLIST_API_BASE_URL=http://localhost:8084
ARG VITE_SEARCH_API_BASE_URL=http://localhost:8085
ARG VITE_ANALYTICS_API_BASE_URL=http://localhost:8086
ARG VITE_RECOMMENDATION_API_BASE_URL=http://localhost:8087
ARG VITE_NOTIFICATION_API_BASE_URL=
ARG VITE_API_RETRY_ATTEMPTS=3
ARG VITE_API_RETRY_BASE_DELAY_MS=250
ARG VITE_PLAYBACK_PROGRESS_INTERVAL_MS=1000
ENV VITE_AUTH_API_BASE_URL=${VITE_AUTH_API_BASE_URL}
ENV VITE_CATALOG_API_BASE_URL=${VITE_CATALOG_API_BASE_URL}
ENV VITE_STREAMING_API_BASE_URL=${VITE_STREAMING_API_BASE_URL}
ENV VITE_PLAYLIST_API_BASE_URL=${VITE_PLAYLIST_API_BASE_URL}
ENV VITE_SEARCH_API_BASE_URL=${VITE_SEARCH_API_BASE_URL}
ENV VITE_ANALYTICS_API_BASE_URL=${VITE_ANALYTICS_API_BASE_URL}
ENV VITE_RECOMMENDATION_API_BASE_URL=${VITE_RECOMMENDATION_API_BASE_URL}
ENV VITE_NOTIFICATION_API_BASE_URL=${VITE_NOTIFICATION_API_BASE_URL}
ENV VITE_API_RETRY_ATTEMPTS=${VITE_API_RETRY_ATTEMPTS}
ENV VITE_API_RETRY_BASE_DELAY_MS=${VITE_API_RETRY_BASE_DELAY_MS}
ENV VITE_PLAYBACK_PROGRESS_INTERVAL_MS=${VITE_PLAYBACK_PROGRESS_INTERVAL_MS}
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
RUN npm test
RUN npm run build

FROM nginx:1.27-alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 5173
CMD ["nginx", "-g", "daemon off;"]
