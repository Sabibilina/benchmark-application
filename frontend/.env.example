# Frontend — environment variables
# Vite bakes VITE_* variables at build time.
# In docker-compose, pass these as build args (--build-arg) or use a runtime
# config injection approach when building the production image (Phase 9).

VITE_AUTH_SERVICE_URL=http://localhost:8081
VITE_CATALOG_SERVICE_URL=http://localhost:8082
VITE_STREAMING_SERVICE_URL=http://localhost:8083
VITE_PLAYLIST_SERVICE_URL=http://localhost:8084
VITE_SEARCH_SERVICE_URL=http://localhost:8085
VITE_ANALYTICS_SERVICE_URL=http://localhost:8086
VITE_RECOMMENDATION_SERVICE_URL=http://localhost:8087
