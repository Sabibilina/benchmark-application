# =============================================================================
# Music Streaming Benchmark Application — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# Defaults shown here match the scaled benchmark configuration.
# Do not use these credentials in any internet-facing deployment.
# =============================================================================

# ── Image versions ────────────────────────────────────────────────────────────
CONFLUENT_VERSION=7.6.0
POSTGRES_VERSION=16-alpine
OPENSEARCH_VERSION=2.13.0
CLICKHOUSE_VERSION=24.3
REDIS_VERSION=7.2-alpine
MONGO_VERSION=7.0
PROMETHEUS_VERSION=v2.51.2
GRAFANA_VERSION=10.4.2

# ── Kafka / Zookeeper ─────────────────────────────────────────────────────────
ZOOKEEPER_HOST_PORT=2181
# External Kafka port (host → container). Internal services use kafka:9092.
KAFKA_HOST_PORT=29092

# ── Kafka topic partition counts ──────────────────────────────────────────────
# Set BEFORE the first `docker compose up`. Partition count is immutable after
# topic creation (increasing requires --alter; decreasing requires topic deletion).
# playback-events: 12 supports up to 12 analytics + 12 recommendation replicas.
# playlist-events:  6 supports up to 6 notification replicas.
PLAYBACK_EVENTS_PARTITIONS=12
PLAYLIST_EVENTS_PARTITIONS=6

# ── PostgreSQL — Auth Service ─────────────────────────────────────────────────
AUTH_DB_HOST_PORT=5432
AUTH_DB_NAME=authdb
AUTH_DB_USER=authuser
AUTH_DB_PASSWORD=authpass
# HikariCP pool size: at 1 replica × 20 = 20 connections (well within PG max_connections=200)
AUTH_DB_POOL_SIZE=20

# ── PostgreSQL — Catalog Service ──────────────────────────────────────────────
CATALOG_DB_HOST_PORT=5433
CATALOG_DB_NAME=catalogdb
CATALOG_DB_USER=cataloguser
CATALOG_DB_PASSWORD=catalogpass
# At 2 replicas × 20 = 40 connections. Scale to 4 replicas before raising pool size.
CATALOG_DB_POOL_SIZE=20

# ── PostgreSQL — Playlist Service ────────────────────────────────────────────
PLAYLIST_DB_HOST_PORT=5434
PLAYLIST_DB_NAME=playlistdb
PLAYLIST_DB_USER=playlistuser
PLAYLIST_DB_PASSWORD=playlistpass
PLAYLIST_DB_POOL_SIZE=20

# ── PostgreSQL — Recommendation Service ──────────────────────────────────────
RECOMMENDATION_DB_HOST_PORT=5435
RECOMMENDATION_DB_NAME=recommendationdb
RECOMMENDATION_DB_USER=recommendationuser
RECOMMENDATION_DB_PASSWORD=recommendationpass
RECOMMENDATION_DB_POOL_SIZE=20

# ── OpenSearch ────────────────────────────────────────────────────────────────
OPENSEARCH_HOST_PORT=9200
# Heap: min(half node RAM, 31 GB). 1 g is appropriate for a single-node benchmark.
# Increase to 2-4 g on a host with ≥8 GB free before adding a second OS node.
OPENSEARCH_JAVA_OPTS=-Xms1g -Xmx1g

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_HTTP_HOST_PORT=8123
CLICKHOUSE_NATIVE_HOST_PORT=9000
CLICKHOUSE_DB=analyticsdb
CLICKHOUSE_USER=analyticsuser
CLICKHOUSE_PASSWORD=analyticspass

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST_PORT=6379
# maxmemory: recommendation cache for 100 K DAU ≈ 150-200 MB; 512 MB gives 2.5× headroom.
REDIS_MAXMEMORY=512mb

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_HOST_PORT=27017
MONGO_USER=mongouser
MONGO_PASSWORD=mongopass
MONGO_DB=notificationdb

# ── nginx load balancer ───────────────────────────────────────────────────────
# Primary API entry point for both the frontend proxy and k6 load tests.
NGINX_LB_HOST_PORT=80

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_HOST_PORT=9090

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_HOST_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_EXPIRATION_MS=3600000

# ── Kafka topic names ─────────────────────────────────────────────────────────
KAFKA_TOPIC_PLAYBACK_EVENTS=playback-events
KAFKA_TOPIC_PLAYLIST_EVENTS=playlist-events

# ── Streaming service tuning ──────────────────────────────────────────────────
STREAM_SEGMENT_SIZE_BYTES=65536
STREAM_SEGMENT_COUNT=10

# ── Analytics service batch tuning ───────────────────────────────────────────
# Flush to ClickHouse when buffer reaches BATCH_SIZE events OR after
# FLUSH_INTERVAL_MS milliseconds, whichever occurs first.
# Larger batches = fewer ClickHouse parts = better merge performance.
ANALYTICS_BATCH_SIZE=500
ANALYTICS_BATCH_FLUSH_INTERVAL_MS=5000
ANALYTICS_HISTORY_LIMIT=100

# ── Recommendation service tuning ─────────────────────────────────────────────
RECOMMENDATION_DAILY_MIX_SIZE=20
RECOMMENDATION_SIMILAR_SIZE=10
RECOMMENDATION_CACHE_TTL_SECONDS=3600
RECOMMENDATION_KAFKA_CONSUMER_GROUP_ID=recommendation-service

# ── Notification service ──────────────────────────────────────────────────────
NOTIFICATION_KAFKA_CONSUMER_GROUP_ID=notification-service
KAFKA_CONSUMER_GROUP_ID=analytics-service

# ── Search service ────────────────────────────────────────────────────────────
SEARCH_MAX_RESULTS=20
SEARCH_SEED_BATCH_SIZE=500

# ── Service replica counts ────────────────────────────────────────────────────
# These set deploy.replicas in docker-compose.yml.
# Constraints:
#   auth-service:    keep at 1 on first boot (JWT key generation race on fresh volumes).
#                    After keys exist, scale to 2-4: docker compose up --scale auth-service=4
#   analytics/recommendation/notification: capped by Kafka partition counts above.
#   streaming/catalog/search: stateless, scale freely.
# RAM budget (estimate per replica): services ~512 MB, JVM startup overlap peak ~1 GB.
CATALOG_SERVICE_REPLICAS=2
STREAMING_SERVICE_REPLICAS=3
PLAYLIST_SERVICE_REPLICAS=2
SEARCH_SERVICE_REPLICAS=2
ANALYTICS_SERVICE_REPLICAS=2
RECOMMENDATION_SERVICE_REPLICAS=2
NOTIFICATION_SERVICE_REPLICAS=1

# ── Resource limits (cpus / memory per container) ────────────────────────────
# auth-service gets 1.5 cpus because BCrypt hashing is CPU-heavy.
# streaming-service could go to 2.0 if HLS generation becomes the bottleneck.
AUTH_SERVICE_CPU_LIMIT=1.5
AUTH_SERVICE_MEMORY_LIMIT=512m
CATALOG_SERVICE_CPU_LIMIT=1.0
CATALOG_SERVICE_MEMORY_LIMIT=512m
STREAMING_SERVICE_CPU_LIMIT=1.0
STREAMING_SERVICE_MEMORY_LIMIT=512m
PLAYLIST_SERVICE_CPU_LIMIT=1.0
PLAYLIST_SERVICE_MEMORY_LIMIT=512m
SEARCH_SERVICE_CPU_LIMIT=1.0
SEARCH_SERVICE_MEMORY_LIMIT=512m
ANALYTICS_SERVICE_CPU_LIMIT=1.0
ANALYTICS_SERVICE_MEMORY_LIMIT=512m
RECOMMENDATION_SERVICE_CPU_LIMIT=1.0
RECOMMENDATION_SERVICE_MEMORY_LIMIT=512m
NOTIFICATION_SERVICE_CPU_LIMIT=1.0
NOTIFICATION_SERVICE_MEMORY_LIMIT=512m
FRONTEND_CPU_LIMIT=0.5
FRONTEND_MEMORY_LIMIT=256m

# ── Load generator (k6) ───────────────────────────────────────────────────────
# K6_SCENARIO: smoke | catalog_stream | kafka_pipeline | ramp | stress | soak
K6_SCENARIO=ramp
K6_VUS=50
K6_DURATION=5m
LOAD_GENERATOR_CPU_LIMIT=2.0
LOAD_GENERATOR_MEMORY_LIMIT=512m
