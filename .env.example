# =============================================================================
# Music Streaming Benchmark Application — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# Defaults shown here are for local development / Profile A/B (1 replica).
# See SCALABILITY.md §2 for Profile C (calibration) and Profile D (full benchmark).
# Do not use these credentials in any production or internet-facing deployment.
# =============================================================================

# ── Image versions ────────────────────────────────────────────────────────────
CONFLUENT_VERSION=7.6.0
POSTGRES_VERSION=16-alpine
OPENSEARCH_VERSION=2.13.0
CLICKHOUSE_VERSION=24.3
REDIS_VERSION=7.2-alpine
MONGO_VERSION=7.0
PROMETHEUS_VERSION=v2.51.2
GRAFANA_VERSION=10.4.2
NGINX_VERSION=1.27-alpine
PG_EXPORTER_VERSION=v0.15.0
REDIS_EXPORTER_VERSION=v1.61.0
KAFKA_EXPORTER_VERSION=v1.7.0
MONGODB_EXPORTER_VERSION=0.40.0

# ── Kafka / Zookeeper ─────────────────────────────────────────────────────────
ZOOKEEPER_HOST_PORT=2181
# External Kafka port (host → container). Internal services use kafka:9092.
KAFKA_HOST_PORT=29092

# Kafka topic configuration — init-kafka creates these at startup
# Auto-create is DISABLED; topics are pre-created with the correct partition count
# so consumer replicas all receive partitions (not sit idle on 1-partition topics).
KAFKA_TOPIC_PLAYBACK_EVENTS=playback-events
KAFKA_TOPIC_PLAYLIST_EVENTS=playlist-events
# Profile A/B: 1 partition each is fine for smoke/dev (only 1 consumer)
# Profile D: set to 12 and 6 before running Phase 4+ load tests
KAFKA_PLAYBACK_PARTITIONS=12
KAFKA_PLAYLIST_PARTITIONS=6
# Must match Kafka broker count. 1 for single-broker (default); 3 for 3-broker cluster.
KAFKA_REPLICATION_FACTOR=1

# ── PostgreSQL — Auth Service ─────────────────────────────────────────────────
AUTH_DB_HOST_PORT=5432
AUTH_DB_NAME=authdb
AUTH_DB_USER=authuser
AUTH_DB_PASSWORD=authpass
AUTH_DB_SHARED_BUFFERS=128MB
AUTH_DB_WORK_MEM=8MB
AUTH_DB_MAX_CONNECTIONS=200
AUTH_DB_CPU_LIMIT=1.0
AUTH_DB_MEMORY_LIMIT=512m

# ── PostgreSQL — Catalog Service ──────────────────────────────────────────────
CATALOG_DB_HOST_PORT=5433
CATALOG_DB_NAME=catalogdb
CATALOG_DB_USER=cataloguser
CATALOG_DB_PASSWORD=catalogpass
# Larger shared_buffers: catalog is read-heavy, bigger buffer pool reduces IO
CATALOG_DB_SHARED_BUFFERS=256MB
CATALOG_DB_WORK_MEM=8MB
CATALOG_DB_MAX_CONNECTIONS=200
CATALOG_DB_CPU_LIMIT=1.0
CATALOG_DB_MEMORY_LIMIT=512m

# ── PostgreSQL — Playlist Service ────────────────────────────────────────────
PLAYLIST_DB_HOST_PORT=5434
PLAYLIST_DB_NAME=playlistdb
PLAYLIST_DB_USER=playlistuser
PLAYLIST_DB_PASSWORD=playlistpass
PLAYLIST_DB_SHARED_BUFFERS=128MB
PLAYLIST_DB_WORK_MEM=8MB
PLAYLIST_DB_MAX_CONNECTIONS=200
PLAYLIST_DB_CPU_LIMIT=1.0
PLAYLIST_DB_MEMORY_LIMIT=512m

# ── PostgreSQL — Recommendation Service ──────────────────────────────────────
RECOMMENDATION_DB_HOST_PORT=5435
RECOMMENDATION_DB_NAME=recommendationdb
RECOMMENDATION_DB_USER=recommendationuser
RECOMMENDATION_DB_PASSWORD=recommendationpass
RECOMMENDATION_DB_SHARED_BUFFERS=128MB
RECOMMENDATION_DB_WORK_MEM=8MB
RECOMMENDATION_DB_MAX_CONNECTIONS=200
RECOMMENDATION_DB_CPU_LIMIT=1.0
RECOMMENDATION_DB_MEMORY_LIMIT=512m

# ── HikariCP connection pool (applies to all DB-connected app services) ───────
# Formula: replicas × HIKARI_MAX_POOL_SIZE must stay below DB max_connections.
# At 4 catalog replicas × 10 = 40 connections (well within max_connections=200).
HIKARI_MAX_POOL_SIZE=10
HIKARI_MIN_IDLE=2

# ── OpenSearch ────────────────────────────────────────────────────────────────
OPENSEARCH_HOST_PORT=9200
# Heap: never exceed 31g (compressed OOP boundary). Profile A/B: 1g. Profile D: 2g+.
# GC pauses at 512m are frequent under search load; 1g is the minimum for benchmarks.
OPENSEARCH_HEAP=1g
OPENSEARCH_CPU_LIMIT=2.0
OPENSEARCH_MEMORY_LIMIT=3g

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_HTTP_HOST_PORT=8123
CLICKHOUSE_NATIVE_HOST_PORT=9000
CLICKHOUSE_DB=analyticsdb
CLICKHOUSE_USER=analyticsuser
CLICKHOUSE_PASSWORD=analyticspass
CLICKHOUSE_CPU_LIMIT=2.0
CLICKHOUSE_MEMORY_LIMIT=4g
CLICKHOUSE_MEMORY_RESERVATION=2g

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST_PORT=6379
# Hard memory cap prevents Redis from OOM-ing the host under key churn.
# allkeys-lru evicts cold keys rather than refusing writes when full.
# At 100K DAU × ~1KB/key the recommendation cache fits within 256mb.
REDIS_MAXMEMORY=256mb
REDIS_CPU_LIMIT=0.5
REDIS_MEMORY_LIMIT=512m

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_HOST_PORT=27017
MONGO_USER=mongouser
MONGO_PASSWORD=mongopass
MONGO_DB=notificationdb
MONGO_CPU_LIMIT=1.0
MONGO_MEMORY_LIMIT=1g

# ── Infrastructure resource limits ────────────────────────────────────────────
ZOOKEEPER_CPU_LIMIT=0.5
ZOOKEEPER_MEMORY_LIMIT=512m
KAFKA_CPU_LIMIT=2.0
KAFKA_MEMORY_LIMIT=2g

# ── Prometheus exporters (singletons) ─────────────────────────────────────────
# These exporters expose metrics from infrastructure components to Prometheus.
# Each adds ~32-64 MB RAM — total overhead ~300 MB across all 4 exporters.

# ── nginx load balancer ───────────────────────────────────────────────────────
# All API traffic enters on port 80. App services no longer bind host ports.
# The resolver 127.0.0.11 valid=10s in nginx.conf picks up new replicas within 10s.
NGINX_LB_HOST_PORT=80
NGINX_LB_CPU_LIMIT=0.5
NGINX_LB_MEMORY_LIMIT=128m

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_HOST_PORT=9090

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_HOST_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_EXPIRATION_MS=3600000

# ── Streaming service tuning ──────────────────────────────────────────────────
STREAM_SEGMENT_SIZE_BYTES=65536
STREAM_SEGMENT_COUNT=10

# ── Analytics — ClickHouse batch insert tuning ────────────────────────────────
# Flush when ANALYTICS_BATCH_SIZE events are buffered OR after ANALYTICS_BATCH_FLUSH_MS ms.
# Prevents the "Too many parts" ClickHouse anti-pattern from single-row inserts.
# At 40K events/s peak, 500 events accumulate in ~12ms; the 5s timer is a safety net.
ANALYTICS_BATCH_SIZE=500
ANALYTICS_BATCH_FLUSH_MS=5000
ANALYTICS_HISTORY_LIMIT=100

# ── Search service ────────────────────────────────────────────────────────────
SEARCH_MAX_RESULTS=20
SEARCH_SEED_BATCH_SIZE=500

# ── Recommendation service ────────────────────────────────────────────────────
RECOMMENDATION_DAILY_MIX_SIZE=20
RECOMMENDATION_SIMILAR_SIZE=10
RECOMMENDATION_CACHE_TTL_SECONDS=3600

# =============================================================================
# RUNTIME PROFILE: REPLICA COUNTS
# See SCALABILITY.md §2 and §5 for full profile descriptions.
#
# Profile A/B (dev / smoke) — all values below are Profile A/B defaults.
# Profile D (full benchmark) — copy the "Profile D" section from SCALABILITY.md.
# NEVER scale Kafka consumers beyond their topic's partition count.
# =============================================================================

# Profile A/B (default — 1 replica each, minimal resource use)
AUTH_SERVICE_REPLICAS=1
CATALOG_SERVICE_REPLICAS=1
STREAMING_SERVICE_REPLICAS=1
PLAYLIST_SERVICE_REPLICAS=1
SEARCH_SERVICE_REPLICAS=1
ANALYTICS_SERVICE_REPLICAS=1
RECOMMENDATION_SERVICE_REPLICAS=1
NOTIFICATION_SERVICE_REPLICAS=1

# Profile D replica counts (uncomment and replace defaults for full benchmark runs):
# NOTE: AUTH_SERVICE_REPLICAS is intentionally absent from this section.
#   auth-service keeps container_name=auth-service (prevents accidental --scale) and
#   must run as exactly 1 replica. RSA key files are written once at startup; a second
#   replica would race to overwrite them. If you need auth throughput, scale upstream
#   through nginx-lb — but keep the auth-service container count at 1.
# CATALOG_SERVICE_REPLICAS=4
# STREAMING_SERVICE_REPLICAS=8
# PLAYLIST_SERVICE_REPLICAS=3
# SEARCH_SERVICE_REPLICAS=4
# ANALYTICS_SERVICE_REPLICAS=4      # must be <= KAFKA_PLAYBACK_PARTITIONS
# RECOMMENDATION_SERVICE_REPLICAS=3 # must be <= KAFKA_PLAYBACK_PARTITIONS
# NOTIFICATION_SERVICE_REPLICAS=2   # must be <= KAFKA_PLAYLIST_PARTITIONS

# ── Application service resource limits (per replica) ────────────────────────
AUTH_SERVICE_CPU_LIMIT=1.0
AUTH_SERVICE_MEMORY_LIMIT=512m
CATALOG_SERVICE_CPU_LIMIT=1.0
CATALOG_SERVICE_MEMORY_LIMIT=512m
STREAMING_SERVICE_CPU_LIMIT=1.0
STREAMING_SERVICE_MEMORY_LIMIT=512m
PLAYLIST_SERVICE_CPU_LIMIT=1.0
PLAYLIST_SERVICE_MEMORY_LIMIT=512m
SEARCH_SERVICE_CPU_LIMIT=1.0
SEARCH_SERVICE_MEMORY_LIMIT=512m
ANALYTICS_SERVICE_CPU_LIMIT=1.0
ANALYTICS_SERVICE_MEMORY_LIMIT=512m
RECOMMENDATION_SERVICE_CPU_LIMIT=1.0
RECOMMENDATION_SERVICE_MEMORY_LIMIT=512m
NOTIFICATION_SERVICE_CPU_LIMIT=1.0
NOTIFICATION_SERVICE_MEMORY_LIMIT=512m

# ── Load generator (k6) ───────────────────────────────────────────────────────
# Scenarios: smoke | streaming | full | peak
# See SCALABILITY.md §15 for phase descriptions and VU counts.
K6_SCENARIO=full
K6_VUS=50
K6_DURATION=5m
LOAD_GENERATOR_CPU_LIMIT=2.0
LOAD_GENERATOR_MEMORY_LIMIT=512m
