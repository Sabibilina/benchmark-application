# Shared Docker Compose defaults for the benchmark application.
# Copy to .env for local overrides. Do not commit real .env files.

COMPOSE_PROJECT_NAME=benchmark-application

# Shared infrastructure ports
KAFKA_HOST_PORT=9092
PROMETHEUS_HOST_PORT=9090
GRAFANA_HOST_PORT=3001
OPENSEARCH_HOST_PORT=9200
CLICKHOUSE_HTTP_HOST_PORT=8123
CLICKHOUSE_NATIVE_HOST_PORT=9000
MONGO_HOST_PORT=27017
REDIS_HOST_PORT=6379

# Application host ports reserved for later service implementations
AUTH_SERVICE_HOST_PORT=8081
CATALOG_SERVICE_HOST_PORT=8082
STREAMING_SERVICE_HOST_PORT=8083
PLAYLIST_SERVICE_HOST_PORT=8084
SEARCH_SERVICE_HOST_PORT=8085
ANALYTICS_SERVICE_HOST_PORT=8086
RECOMMENDATION_SERVICE_HOST_PORT=8087
NOTIFICATION_SERVICE_HOST_PORT=8088

# Placeholder and service resource limits
DEFAULT_SERVICE_CPUS=0.50
DEFAULT_SERVICE_MEMORY=512m
INFRA_CPUS=1.00
INFRA_MEMORY=1g
OPENSEARCH_MEMORY=2g
OPENSEARCH_INITIAL_ADMIN_PASSWORD=BenchmarkAdmin123!
CLICKHOUSE_MEMORY=2g
KAFKA_MEMORY=1g
GRAFANA_MEMORY=512m
PROMETHEUS_MEMORY=512m
K6_MEMORY=512m

# Shared configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
JWT_PUBLIC_KEY_PATH=/run/config/jwt/public.pem
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt/private.pem
JWT_ISSUER=benchmark-auth
JWT_ACCESS_TOKEN_TTL=PT1H
CATALOG_DATASET_PATH=/app/data/catalog.csv
CATALOG_INGESTION_ENABLED=true
CATALOG_DEFAULT_PAGE_SIZE=20
CATALOG_MAX_PAGE_SIZE=100

SEARCH_INDEX_NAME=songs
SEARCH_CATALOG_DATASET_PATH=/app/data/catalog.csv
SEARCH_INDEXING_ENABLED=true
SEARCH_INDEX_BATCH_SIZE=500
SEARCH_DEFAULT_PAGE_SIZE=20
SEARCH_MAX_PAGE_SIZE=100

ANALYTICS_PLAYBACK_EVENTS_TOPIC=playback-events
ANALYTICS_KAFKA_CONSUMER_GROUP_ID=analytics-service
ANALYTICS_DEFAULT_PAGE_SIZE=20
ANALYTICS_MAX_PAGE_SIZE=100
ANALYTICS_GLOBAL_CHART_LIMIT=50

RECOMMENDATION_PLAYBACK_EVENTS_TOPIC=playback-events
RECOMMENDATION_KAFKA_CONSUMER_GROUP_ID=recommendation-service
RECOMMENDATION_DEFAULT_LIMIT=10
RECOMMENDATION_MAX_LIMIT=50
RECOMMENDATION_CACHE_TTL=PT5M

NOTIFICATION_PLAYLIST_EVENTS_TOPIC=playlist-events
NOTIFICATION_KAFKA_CONSUMER_GROUP_ID=notification-service

PROMETHEUS_SCRAPE_INTERVAL=15s

# Database defaults for local-only development containers
POSTGRES_USER=benchmark
POSTGRES_PASSWORD=benchmark
MONGO_INITDB_ROOT_USERNAME=benchmark
MONGO_INITDB_ROOT_PASSWORD=benchmark
CLICKHOUSE_USER=benchmark
CLICKHOUSE_PASSWORD=benchmark
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
