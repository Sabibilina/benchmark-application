# Copy this file to .env and fill in values before running docker compose.
# .env is gitignored. This file is committed as documentation.

# Docker Compose project name
COMPOSE_PROJECT_NAME=musicapp

# Shared database password — used by all postgres-* containers
POSTGRES_PASSWORD=changeme

# Kafka bootstrap address (internal Docker hostname)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# MinIO object storage credentials
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123

# Grafana admin password
GRAFANA_ADMIN_PASSWORD=admin
