# Load Generator (k6) — environment variables
# Copy to .env and adjust before running.
# All traffic routes through nginx-lb; direct service URLs below are for debugging only.

# ── Primary entry point ───────────────────────────────────────────────────────
# All load-test traffic enters here. Must match the nginx-lb service name / host port.
NGINX_LB_URL=http://nginx-lb

# ── Scenario selection ────────────────────────────────────────────────────────
# Comma-separated list of scenarios to run, or "all".
# Valid values: streaming_playback, catalog_search, auth_login,
#               playlist_mutations, recommendations, all
K6_SCENARIOS=all

# Legacy single-scenario selector (backward compat with old main.js).
# Set to "smoke" to run a quick sanity check at very low rates.
K6_SCENARIO=ramp

# ── Per-scenario peak arrival rates (iterations or requests per second) ───────
# From SCALABILITY.md §1. Reduce for local testing; keep full values for benchmarking.
#
# WARNING — nginx-lb rate limits per source IP (infra/nginx-lb/nginx.conf):
#   auth:      20 r/s/IP  (burst 60)   — target 500 r/s EXCEEDS this limit
#   streaming: 200 r/s/IP (burst 1000) — target 20000 r/s EXCEEDS this limit
#   api:       500 r/s/IP (burst 1000) — target 4000 r/s EXCEEDS this limit
#
# Resolution options before running at full targets:
#   1. Raise rate limits in infra/nginx-lb/nginx.conf (auth_rl, stream_rl, api_rl)
#   2. Run k6 from multiple IPs (distributed k6, ≥4 instances for streaming)
#   3. Accept 503s as part of the measured SUT behavior
K6_STREAMING_RATE=20000
K6_CATALOG_RATE=4000
K6_AUTH_RATE=500
K6_PLAYLIST_RATE=200
K6_RECOMMEND_RATE=400

# ── Test phase durations ──────────────────────────────────────────────────────
K6_PHASE_WARMUP_DURATION=5m
K6_PHASE_STEADY_DURATION=15m
K6_PHASE_BURST_DURATION=2m

# ── Seed data ─────────────────────────────────────────────────────────────────
# Number of users to register.
#   - For smoke / dev runs: 100–500 is enough.
#   - For full benchmark (streaming_playback at 20K iter/s): 25000.
SEED_USER_COUNT=500

# Batch size for parallel HTTP registrations in seed.js.
SEED_BATCH_SIZE=50

# ── Kafka exporter ────────────────────────────────────────────────────────────
# Prometheus metrics endpoint exposed by danielqsj/kafka-exporter (see docker-compose.yml).
# Used to poll consumer group lag during the test and in kafka-lag-check.js.
KAFKA_EXPORTER_URL=http://kafka-exporter:9308

# Kafka consumer lag threshold for kafka-lag-check.js (messages).
LAG_THRESHOLD=10000

# Polling interval for kafka-lag-check.js (seconds).
POLL_INTERVAL_S=10

# Duration for the standalone lag-check run.
CHECK_DURATION=2m

# ── k6 output ─────────────────────────────────────────────────────────────────
# Uncomment to push metrics to Prometheus remote-write (Grafana).
# K6_OUT=experimental-prometheus-rw
# K6_PROMETHEUS_RW_SERVER_URL=http://prometheus:9090/api/v1/write

# ── Replica count hints (consumed by docker-compose.yml, not k6 scripts) ─────
STREAMING_REPLICAS=3
AUTH_REPLICAS=1
CATALOG_REPLICAS=2
SEARCH_REPLICAS=2
PLAYLIST_REPLICAS=2
ANALYTICS_REPLICAS=2
RECOMMENDATION_REPLICAS=2
NOTIFICATION_REPLICAS=1

# ── Direct service URLs (for debugging; bypasses nginx-lb) ───────────────────
AUTH_SERVICE_URL=http://localhost:8081
CATALOG_SERVICE_URL=http://localhost:8082
STREAMING_SERVICE_URL=http://localhost:8083
PLAYLIST_SERVICE_URL=http://localhost:8084
SEARCH_SERVICE_URL=http://localhost:8085
ANALYTICS_SERVICE_URL=http://localhost:8086
RECOMMENDATION_SERVICE_URL=http://localhost:8087
NOTIFICATION_SERVICE_URL=http://localhost:8088

# ── Legacy VU / duration (backward compat — unused by main.js arrival-rate) ──
K6_VUS=10
K6_DURATION=60s
