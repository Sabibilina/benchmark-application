# Load Generator (k6) — environment variables
# Used when running k6 outside of docker-compose.

AUTH_SERVICE_URL=http://localhost:8081
CATALOG_SERVICE_URL=http://localhost:8082
STREAMING_SERVICE_URL=http://localhost:8083
PLAYLIST_SERVICE_URL=http://localhost:8084
SEARCH_SERVICE_URL=http://localhost:8085
ANALYTICS_SERVICE_URL=http://localhost:8086
RECOMMENDATION_SERVICE_URL=http://localhost:8087

# Virtual users and test duration; override via -e flag or .env
K6_VUS=10
K6_DURATION=60s
