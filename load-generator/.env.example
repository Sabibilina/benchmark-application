# Load Generator (k6) — environment variables
# All traffic routes through nginx-lb. Individual service URLs are not used.

# nginx-lb base URL — all k6 HTTP calls target this endpoint
NGINX_LB_URL=http://nginx-lb:80

# ── Scenario selection ─────────────────────────────────────────────────────────
# K6_SCENARIO selects the workload scenario:
#
#   smoke     — 5 VUs, 2 min. Verifies basic auth + catalog connectivity only.
#               Use before any load test to confirm the stack is healthy.
#
#   streaming — 50 VUs, 5 min. Auth + catalog + search + stream hot path (Phase 2).
#
#   full      — APP_VUS VUs, APP_DURATION. All 8 flows: auth, catalog, search,
#               stream, playlist, analytics, recommendations (Phase 3).
#
#   burst     — Ramp to 500 VUs over 5 min, hold 5 min, drain 5 min.
#               Short spike for regression validation.
#
#   ramp      — Phase 4. Ramp to APP_RAMP_TARGET (default 1000) VUs over 5 min,
#               hold 10 min, drain 5 min. REQUIRES Profile D deployment.
#
#   soak      — Phase 6. 2000 VUs constant for 120 min. Memory leak detection.
#               REQUIRES Profile D, ≥32 GB host RAM. Run once per cycle.
#
# Phase 5 (10000 VUs) is in a SEPARATE FILE: load-generator/scripts/phase5-peak.js
# Run it explicitly — it is NOT selectable via K6_SCENARIO.
K6_SCENARIO=full

# VUs and duration for the 'full' scenario only (ignored by other scenarios).
# APP_ prefix avoids conflict with k6's built-in K6_VUS / K6_DURATION env vars,
# which would override options.scenarios and force a default executor.
APP_VUS=50
APP_DURATION=5m

# VU ceiling for the 'ramp' (Phase 4) scenario
APP_RAMP_TARGET=1000
